        <locationX>378</locationX>
        <locationY>40</locationY>
        <defaultConnectorLabel>Exit Flow (Default)</defaultConnectorLabel>
        <rules>
            <name>EventIsForEmergencyRequest</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>SfmapEvent.Type</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>EventTypeValue</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>GetEmergencyRequest</targetReference>
