    <description>Create an emergency visit from an Emergency Request triggered process.</description>
    <interviewLabel>Create a Visit for Emergency Request Event {!$Flow.CurrentDateTime}</interviewLabel>
    <isTemplate>true</isTemplate>
    <label>Create a Visit for Emergency Request Event</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordCreates>
        <description>Create an action plan for the scheduled visit based on the current version of the action plan template.</description>
        <name>CreateActionPlanForScheduledVisit</name>
        <label>Create Action Plan for Scheduled Visit</label>
        <locationX>173</locationX>
        <locationY>523</locationY>
        <assignRecordIdToReference>ActionPlanId</assignRecordIdToReference>
        <inputAssignments>
            <field>ActionPlanTemplateVersionId</field>
            <value>
                <elementReference>ActionPlanTemplateVersionId</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>ActionPlanType</field>
            <value>
                <stringValue>Retail</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Name</field>
            <value>
                <elementReference>ActionPlanTemplateName</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>OwnerId</field>
            <value>
                <elementReference>SfmapEvent.OwnerId</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>StartDate</field>
            <value>
                <elementReference>$Flow.CurrentDateTime</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>TargetId</field>
            <value>
                <elementReference>ScheduledVisit.Id</elementReference>
            </value>
        </inputAssignments>
        <object>ActionPlan</object>
    </recordCreates>
    <recordCreates>
        <description>Create a visit with the specified location, account, instructions, context, the specified start date and time, the specified end date and time, a priority of Medium, and the end user&apos;s ID.</description>
        <name>CreateVisit</name>
        <label>Create Visit</label>
        <locationX>1101</locationX>
        <locationY>42</locationY>
        <assignRecordIdToReference>ScheduledVisit.Id</assignRecordIdToReference>
        <connector>
            <targetReference>IsVisitCreated</targetReference>
        </connector>
        <inputAssignments>
            <field>AccountId</field>
            <value>
                <elementReference>AccountId</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>ContextId</field>
            <value>
                <elementReference>IndividualApplicationId</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>InstructionDescription</field>
            <value>
                <elementReference>VisitInstructions</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>PlaceId</field>
            <value>
                <elementReference>AddressId</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>PlannedVisitEndTime</field>
            <value>
                <elementReference>SfmapEvent.EndDateTime</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>PlannedVisitStartTime</field>
            <value>
                <elementReference>SfmapEvent.StartDateTime</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>VisitPriority</field>
            <value>
                <stringValue>Medium</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>VisitorId</field>
            <value>
                <elementReference>SfmapEvent.OwnerId</elementReference>
            </value>
        </inputAssignments>
        <object>Visit</object>
    </recordCreates>
    <recordLookups>
        <description>Get the action plan template to use to create an action plan for the scheduled visit and store its ID in the ActionPlanTemplateId variable.</description>
        <name>GetActionPlanTemplate</name>
        <label>Get Action Plan Template</label>
        <locationX>1098</locationX>
        <locationY>647</locationY>
        <assignNullValuesIfNoRecordsFound>true</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>DoesActionPlanTemplateExist</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Name</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>ActionPlanTemplateName</elementReference>
            </value>
        </filters>
        <object>ActionPlanTemplate</object>
        <outputAssignments>
            <assignToReference>ActionPlanTemplateId</assignToReference>
            <field>Id</field>
        </outputAssignments>
    </recordLookups>
    <recordLookups>
        <description>Get the latest version of the action plan template and store its ID in the ActionPlanTemplateVersionId variable.</description>
        <name>GetActionPlanTemplateVersion</name>
        <label>Get Action Plan Template Version</label>
        <locationX>636</locationX>
        <locationY>645</locationY>
        <assignNullValuesIfNoRecordsFound>true</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>DoesActionPlanTemplateVersionExist</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>ActionPlanTemplateId</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>ActionPlanTemplateId</elementReference>
            </value>
        </filters>
        <filters>
            <field>Status</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Final</stringValue>
            </value>
        </filters>
        <object>ActionPlanTemplateVersion</object>
        <outputAssignments>
            <assignToReference>ActionPlanTemplateVersionId</assignToReference>
            <field>Id</field>
        </outputAssignments>
    </recordLookups>
    <recordLookups>
