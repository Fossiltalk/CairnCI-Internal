    <decisions>
        <description>Check if Action Plan Template Exists</description>
        <name>DoesActionPlanTemplateExist</name>
        <label>Does Action Plan Template Exist?</label>
        <locationX>956</locationX>
        <locationY>649</locationY>
        <defaultConnectorLabel>Exit Flow (Default)</defaultConnectorLabel>
        <rules>
            <name>ActionPlanTemplateExists</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>ActionPlanTemplateId</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
