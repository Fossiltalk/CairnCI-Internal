{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "yamllint",
      "type": "shell",
      "command": "yamllint -c .yamllint.yml .github/",
      "problemMatcher": {
        "owner": "yamllint",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^(.+):(\\d+):(\\d+):\\s+(warning|error):\\s+(.+)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "group": {
        "kind": "test",
        "isDefault": true
      }
    }
  ]
}
