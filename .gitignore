# Intentionally untracked files Git should ignore.
# See: https://git-scm.com/docs/gitignore

# Salesforce CLI local caches (generated if you run `sf` in this repo)
.sf/
.sfdx/
.localdevserver/
deploy-options.json

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Dependency directories
node_modules/

# Local environment variables
.env

# macOS system files
.DS_Store

# Windows system files
Thumbs.db
ehthumbs.db
[Dd]esktop.ini
$RECYCLE.BIN/
